{
  "features": [
    {
      "name": "payments-v2",
      "summary": "Payment Processing Redesign",
      "jiraFeature": "PAY-1234",
      "enabled": true,
      "sources": {
        "github": {
          "repos": [
            {
              "owner": "myorg",
              "repo": "payments-api",
              "branchPatterns": ["feat/pay-*", "*PAY-1234*"]
            },
            {
              "owner": "myorg",
              "repo": "payments-ui"
            }
          ],
          "prSearchTerms": ["PAY-1234", "payments-v2"]
        },
        "jiraBoards": [
          {
            "boardId": 500,
            "project": "PAY",
            "url": "https://myorg.atlassian.net/jira/software/projects/PAY/boards/500",
            "jql": "status != Done ORDER BY updated DESC"
          }
        ],
        "jiraIssues": ["PAY-1234"]
      }
    },
    {
      "name": "search-reindex",
      "summary": "Search Infrastructure Reindexing",
      "jiraFeature": "SRCH-890",
      "enabled": true,
      "sources": {
        "github": {
          "repos": [
            {
              "owner": "myorg",
              "repo": "search-service",
              "branchPatterns": ["*reindex*", "*SRCH-890*"]
            }
          ],
          "prSearchTerms": ["SRCH-890"]
        },
        "jiraBoards": [],
        "jiraIssues": ["SRCH-890"]
      }
    }
  ]
}
